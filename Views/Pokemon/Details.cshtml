@model ActividadAutonoma.Models.PokemonDetalles

<div class="container text-center mt-4">

    <h1 class="text-capitalize">@Model.Name</h1>

    @if (Model.Sprites != null && !string.IsNullOrEmpty(Model.Sprites.Imagen))
    {
        <img src="@Model.Sprites.Imagen" alt="@Model.Name" width="200" class="mb-3" />
    }

    <p><strong>Altura:</strong> @Model.Height Metros</p>
    <p><strong>Peso:</strong> @Model.Weight</p>

    <h3>Tipos</h3>
    <ul class="list-unstyled">
        @foreach (var tipo in Model.Types)
        {
            <li class="text-capitalize">@tipo.Type.Name</li>
        }
    </ul>

    <h3>Habilidades</h3>
    <ul class="list-unstyled">
        @foreach (var habilidad in Model.Abilities)
        {
            <li class="text-capitalize">@habilidad.Ability.Name</li>
        }
    </ul>

    <a asp-action="Index" class="btn btn-secondary mt-3">Volver</a>

</div>